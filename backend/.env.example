# Firebase Configuration (Values from render.yaml)
FIREBASE_PROJECT_ID=finalyearprojectdata-80bc9
FIREBASE_DATABASE_URL=https://finalyearprojectdata-80bc9-default-rtdb.firebaseio.com
FIREBASE_STORAGE_BUCKET=finalyearprojectdata-80bc9.firebasestorage.app

# Firebase Admin Service Account Credentials
# Download these from: Firebase Console -> Project Settings -> Service Accounts -> Generate New Private Key
FIREBASE_CLIENT_EMAIL=your-service-account-email@finalyearprojectdata-80bc9.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Backend & Security Configuration
PORT=5000
JWT_SECRET=your_local_jwt_secret_key_here

# Service Integrations
AI_SERVICE_URL=http://localhost:5001
FRONTEND_URL=http://localhost:3000
